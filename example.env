# Payroll-Jam Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# LAYER GUIDE:
#   VITE_*   → Frontend (Vite/Vercel). Bundled into the client — use ONLY the
#              publishable/anon key here. NEVER put the secret/service_role key
#              behind a VITE_ prefix — Vite inlines every VITE_* var into the
#              public JS bundle, so doing so leaks it to anyone who loads the site.
#   CRON_*   → Vercel serverless functions only.
#   The secret/service-role key belongs in exactly two places, both server-only:
#     - Vercel → Project Settings → Environment Variables → SUPABASE_SERVICE_ROLE_KEY
#       (used by api/_supabaseAdmin.ts and api/cron/*)
#     - Supabase Dashboard → Project Settings → Edge Functions → Secrets
#       (auto-injected as SUPABASE_SERVICE_ROLE_KEY; do not set manually there)
#   It must never appear as VITE_SUPABASE_SERVICE_ROLE_KEY anywhere.

# ─── Supabase (Frontend) ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API Keys
# Use the publishable key (sb_publishable_...) here, or the legacy anon key if
# you haven't migrated off Legacy JWT Secret yet. Either way: never the secret key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here
# ─── Google AI / Gemini (Frontend) ───────────────────────────────────────────
# Used by src/services/aiService.ts for the in-app AI assistant
# Get from: Google AI Studio → API Keys
VITE_GOOGLE_AI_KEY=your-google-ai-key-here

# ─── DimePay Payments (Frontend) ─────────────────────────────────────────────
# Get from: DimePay merchant dashboard
# Sandbox keys are safe for development; never use production keys locally.
VITE_DIMEPAY_API_KEY_SANDBOX=your-sandbox-api-key
VITE_DIMEPAY_MERCHANT_ID_SANDBOX=your-sandbox-merchant-id
VITE_DIMEPAY_CLIENT_ID_SANDBOX=your-sandbox-client-id

VITE_DIMEPAY_API_KEY_PROD=your-production-api-key
VITE_DIMEPAY_MERCHANT_ID_PROD=your-production-merchant-id
VITE_DIMEPAY_CLIENT_ID_PROD=your-production-client-id

# Backend DimePay server-to-server credentials.
# DIMEPAY_SECRET_KEY also verifies DimePay webhook JWTs.
DIMEPAY_CLIENT_KEY=your-dimepay-client-key
DIMEPAY_SECRET_KEY=your-dimepay-secret-key
# DimePay must receive public webhook/redirect URLs; localhost will be rejected.
# For local end-to-end gateway testing, use a deployed domain or tunnel URL.
DIMEPAY_PUBLIC_BASE_URL=https://www.payrolljam.com

# ─── API Base URL (Frontend) ──────────────────────────────────────────────────
# Points to the Vercel serverless API routes in /api/
# Development: http://localhost:3000
# Production: https://www.payrolljam.com
VITE_API_URL=http://localhost:3000

# ─── Vercel Serverless Functions ─────────────────────────────────────────────
# Used by api/cron/dimepay-billing.ts and api/cron/subscription-expiry-check.ts
# to authenticate cron requests
CRON_SECRET=your-cron-secret-here

# ─── Supabase Edge Function Secrets ──────────────────────────────────────────
# These are NOT set here. Set them in:
#   Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# Required secrets:
#   SUPABASE_URL              — auto-injected by Supabase (do not set manually)
#   SUPABASE_SERVICE_ROLE_KEY — auto-injected by Supabase (do not set manually).
#                               Under the new API Keys system this holds the
#                               secret key (sb_secret_...) instead of the legacy
#                               service_role JWT — Supabase re-injects it automatically.
#   GEMINI_API_KEY            — used by payroll-chat function
#   BREVO_API_KEY             — used by send-email function
#   SMTP_FROM_NAME            — sender display name (e.g., "Payroll-Jam")
#   SMTP_FROM_EMAIL           — sender email address

# ─── Vercel Server-Side (api/ functions) ─────────────────────────────────────
# Set these in Vercel → Project Settings → Environment Variables, NOT in this
# file, and NEVER with a VITE_ prefix. Used by api/_supabaseAdmin.ts and
# api/cron/subscription-expiry-check.ts to bypass RLS for admin operations.
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY  — the secret key (sb_secret_...), server-only
