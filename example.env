# Payroll-Jam Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# LAYER GUIDE:
#   VITE_*   → Frontend (Vite/Vercel). Bundled into the client — use only public/anon keys here.
#   CRON_*   → Vercel serverless functions only.
#   The Supabase edge function vars (SUPABASE_SERVICE_ROLE_KEY, GEMINI_API_KEY, BREVO_API_KEY,
#   SMTP_FROM_*) are set in the Supabase Dashboard → Project Settings → Edge Functions,
#   NOT in this file.

# ─── Supabase (Frontend) ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google AI / Gemini (Frontend) ───────────────────────────────────────────
# Used by src/services/aiService.ts for the in-app AI assistant
# Get from: Google AI Studio → API Keys
VITE_GOOGLE_AI_KEY=your-google-ai-key-here

# ─── DimePay Payments (Frontend) ─────────────────────────────────────────────
# Get from: DimePay merchant dashboard
# Sandbox keys are safe for development; never use production keys locally.
VITE_DIMEPAY_API_KEY_SANDBOX=your-sandbox-api-key
VITE_DIMEPAY_MERCHANT_ID_SANDBOX=your-sandbox-merchant-id
VITE_DIMEPAY_CLIENT_ID_SANDBOX=your-sandbox-client-id

VITE_DIMEPAY_API_KEY_PROD=your-production-api-key
VITE_DIMEPAY_MERCHANT_ID_PROD=your-production-merchant-id
VITE_DIMEPAY_CLIENT_ID_PROD=your-production-client-id

# ─── API Base URL (Frontend) ──────────────────────────────────────────────────
# Points to the Vercel serverless API routes in /api/
# Development: http://localhost:3000
# Production: https://www.payrolljam.com
VITE_API_URL=http://localhost:3000

# ─── Vercel Serverless Functions ─────────────────────────────────────────────
# Used by src/app/api/cron/expiry-check/route.ts to authenticate cron requests
CRON_SECRET=your-cron-secret-here

# ─── Supabase Edge Function Secrets ──────────────────────────────────────────
# These are NOT set here. Set them in:
#   Supabase Dashboard → Project Settings → Edge Functions → Secrets
#
# Required secrets:
#   SUPABASE_URL              — auto-injected by Supabase (do not set manually)
#   SUPABASE_SERVICE_ROLE_KEY — auto-injected by Supabase (do not set manually)
#   GEMINI_API_KEY            — used by payroll-chat function
#   BREVO_API_KEY             — used by send-email function
#   SMTP_FROM_NAME            — sender display name (e.g., "Payroll-Jam")
#   SMTP_FROM_EMAIL           — sender email address
